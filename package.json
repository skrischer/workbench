{
  "name": "@skrischer/workbench",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "workbench": "dist/tui/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "dev": "tsc --watch",
    "dev:tui": "tsx watch src/tui/index.tsx",
    "dev:gateway": "tsx watch --ignore 'src/web/**' src/gateway/entry.ts -- --dev",
    "check": "tsc --noEmit",
    "dev:web": "vite --config src/web/vite.config.ts",
    "build:web": "vite build --config src/web/vite.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skrischer/workbench.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/skrischer/workbench/issues"
  },
  "homepage": "https://github.com/skrischer/workbench#readme",
  "description": "Workbench — AI Dev OS",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/middie": "^9.3.1",
    "@fastify/static": "^8.0.3",
    "@fastify/websocket": "^11.2.0",
    "@lancedb/lancedb": "^0.26.2",
    "@tailwindcss/vite": "^4.1.0",
    "@xenova/transformers": "^2.17.2",
    "ajv": "^8.18.0",
    "cli-highlight": "^2.1.11",
    "clsx": "^2.1.0",
    "commander": "^14.0.3",
    "fastify": "^5.8.2",
    "ink": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "lucide-react": "^0.500.0",
    "marked": "^15.0.0",
    "marked-terminal": "^7.0.0",
    "minimatch": "^10.2.4",
    "react": "^19.1.0",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.0.0",
    "tailwindcss": "^4.1.0",
    "ws": "^8.19.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@fastify/cors": "^11.2.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.5.0",
    "ink-testing-library": "^4.0.0",
    "jsdom": "^27.0.1",
    "react-router-dom": "^7.13.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.0",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs",
      "sharp"
    ]
  }
}
